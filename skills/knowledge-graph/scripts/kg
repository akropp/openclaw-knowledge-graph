#!/usr/bin/env node

import { resolve, dirname } from "node:path";
import { readFileSync, existsSync, mkdirSync } from "node:fs";
import { homedir } from "node:os";
import { createInterface } from "node:readline";
import { program } from "commander";
import { GraphDB } from "../../../dist/lib/graph-db.js";
import { fuse } from "../../../dist/lib/rrf.js";
import { 
  loadConfig,
  saveConfig,
  CONFIG_PATH,
  getConfigValue,
  setConfigValue
} from "../../../dist/lib/config.js";
import {
  ingestSessions,
  ingestMarkdown,
  ingestFactmem,
  ingestAll,
  resetState
} from "../../../dist/lib/ingest.js";

function getDbPath(opts) {
  if (opts?.db) return resolve(opts.db);
  if (process.env.KG_DB_PATH) return resolve(process.env.KG_DB_PATH);
  
  // Load from config file
  const config = loadConfig();
  const dbPath = resolve(config.dbPath);
  
  // Ensure parent directory exists
  const dbDir = dirname(dbPath);
  if (!existsSync(dbDir)) mkdirSync(dbDir, { recursive: true });
  
  return dbPath;
}

function openDb(opts) {
  return new GraphDB(getDbPath(opts));
}

program
  .name("kg")
  .description("Knowledge graph CLI for OpenClaw")
  .version("0.1.0")
  .option("--db <path>", "Database file path");

program
  .command("init")
  .description("Initialize knowledge graph configuration interactively")
  .action(async () => {
    const rl = createInterface({
      input: process.stdin,
      output: process.stdout,
    });

    const question = (prompt) => new Promise((resolve) => rl.question(prompt, resolve));

    console.log("Knowledge Graph Configuration Setup");
    console.log("===================================\n");

    // Check if config exists
    if (existsSync(CONFIG_PATH)) {
      const answer = await question(`Config file already exists at ${CONFIG_PATH}\nOverwrite? (y/N): `);
      if (!answer.toLowerCase().startsWith("y")) {
        console.log("Initialization cancelled.");
        rl.close();
        return;
      }
    }

    const config = loadConfig(); // Load defaults or existing
    
    // Set defaults if not present
    if (!config.dbPath) {
      config.dbPath = resolve(homedir(), "shared", "graph.db");
    }
    if (!config.maxHops) {
      config.maxHops = 2;
    }

    // DB Path
    const dbPathAnswer = await question(`Database path [${config.dbPath}]: `);
    if (dbPathAnswer.trim()) {
      config.dbPath = dbPathAnswer.trim();
    }

    // Max Hops
    const maxHopsAnswer = await question(`Max hops for queries [${config.maxHops}]: `);
    if (maxHopsAnswer.trim()) {
      config.maxHops = parseInt(maxHopsAnswer.trim(), 10);
    }

    // LLM Configuration
    const llmEnabled = await question("Enable LLM extraction? (y/N): ");
    if (llmEnabled.toLowerCase().startsWith("y")) {
      if (!config.llm) config.llm = {};

      const baseUrl = await question("LLM base URL [http://mac-mini.tailcd0984.ts.net:11434]: ");
      config.llm.baseUrl = baseUrl.trim() || "http://mac-mini.tailcd0984.ts.net:11434";

      const model = await question("LLM model [qwen2.5:14b]: ");
      config.llm.model = model.trim() || "qwen2.5:14b";
    } else {
      delete config.llm;
    }

    saveConfig(config);
    console.log(`\n✓ Configuration saved to ${CONFIG_PATH}`);
    rl.close();
  });

program
  .command("config")
  .description("View or modify configuration")
  .argument("[subcommand]", "Subcommand: get, set, path")
  .argument("[key]", "Config key (for get/set)")
  .argument("[value]", "Config value (for set)")
  .action((subcommand, key, value) => {
    const config = loadConfig();

    if (!subcommand) {
      // No subcommand: print current config
      console.log(JSON.stringify(config, null, 2));
      return;
    }

    switch (subcommand) {
      case "get":
        if (!key) {
          console.error("Usage: kg config get <key>");
          process.exitCode = 1;
          return;
        }
        const val = getConfigValue(config, key);
        if (val === undefined) {
          console.error(`Key "${key}" not found`);
          process.exitCode = 1;
        } else {
          console.log(typeof val === "object" ? JSON.stringify(val, null, 2) : val);
        }
        break;

      case "set":
        if (!key || value === undefined) {
          console.error("Usage: kg config set <key> <value>");
          process.exitCode = 1;
          return;
        }
        setConfigValue(config, key, value);
        saveConfig(config);
        console.log(`✓ Set ${key} = ${value}`);
        break;

      case "path":
        console.log(CONFIG_PATH);
        break;

      default:
        console.error(`Unknown config subcommand: ${subcommand}`);
        console.error("Valid subcommands: get, set, path");
        process.exitCode = 1;
    }
  });

program
  .command("add <subject> <predicate> <object>")
  .description("Add a triple (subject -predicate-> object)")
  .option("--type <type>", "Entity type for subject", "unknown")
  .option("--confidence <n>", "Confidence score (0-1)", "1.0")
  .option("--source <s>", "Source identifier")
  .action((subject, predicate, object, opts) => {
    const db = openDb(program.opts());
    try {
      db.addEntity(subject, opts.type);
      db.addTriple(subject, predicate, object, {
        confidence: parseFloat(opts.confidence),
        source: opts.source,
      });
      console.log(`Added: ${subject} -[${predicate}]-> ${object}`);
    } finally {
      db.close();
    }
  });

program
  .command("prop <entity> <key> <value>")
  .description("Set a property on an entity")
  .option("--source <s>", "Source identifier")
  .action((entity, key, value, opts) => {
    const db = openDb(program.opts());
    try {
      db.addProperty(entity, key, value, { source: opts.source });
      console.log(`Set ${entity}.${key} = ${value}`);
    } finally {
      db.close();
    }
  });

program
  .command("query <entity>")
  .description("Multi-hop traversal from an entity")
  .option("--hops <n>", "Number of hops", "2")
  .option("--kind <type>", "Filter type: relationships|properties|all", "all")
  .option("--format <fmt>", "Output format: human|jsonl", "human")
  .action((entity, opts) => {
    const db = openDb(program.opts());
    try {
      const kind = opts.kind;
      if (!["relationships", "properties", "all"].includes(kind)) {
        console.error(`Invalid kind: ${kind}. Must be one of: relationships, properties, all`);
        process.exitCode = 1;
        return;
      }
      const results = db.query(entity, parseInt(opts.hops), { kind });
      if (opts.format === "jsonl") {
        for (const r of results) {
          console.log(JSON.stringify({ text: r.path, score: 1.0 / (r.depth + 1), source: "graph", meta: { depth: r.depth, entity_id: r.entity_id } }));
        }
      } else {
        if (results.length === 0) {
          console.log(`No results found for "${entity}"`);
          return;
        }
        for (const r of results) {
          const indent = "  ".repeat(r.depth);
          console.log(`${indent}[depth ${r.depth}] ${r.path}`);
        }
      }
    } finally {
      db.close();
    }
  });

program
  .command("search <text>")
  .description("Search entities by name")
  .option("--format <fmt>", "Output format: human|jsonl", "human")
  .action((text, opts) => {
    const db = openDb(program.opts());
    try {
      const results = db.search(text);
      if (opts.format === "jsonl") {
        for (const r of results) {
          console.log(JSON.stringify({ text: `${r.display_name} (${r.entity_type})`, score: 1.0, source: "graph", meta: { name: r.name } }));
        }
      } else {
        if (results.length === 0) {
          console.log(`No entities found matching "${text}"`);
          return;
        }
        for (const r of results) {
          console.log(`  ${r.display_name} [${r.entity_type}]`);
        }
      }
    } finally {
      db.close();
    }
  });

program
  .command("get <entity>")
  .description("Get full entity details")
  .option("--format <fmt>", "Output format: human|jsonl", "human")
  .action((entity, opts) => {
    const db = openDb(program.opts());
    try {
      const detail = db.getEntity(entity);
      if (!detail) {
        console.log(`Entity "${entity}" not found`);
        process.exitCode = 1;
        return;
      }
      if (opts.format === "jsonl") {
        console.log(JSON.stringify(detail));
      } else {
        console.log(`${detail.entity.display_name} [${detail.entity.entity_type}]`);
        if (detail.triples.length > 0) {
          console.log("  Relationships:");
          for (const t of detail.triples) {
            if (t.direction === "outgoing") {
              console.log(`    -[${t.predicate}]-> ${t.related_name} [${t.related_type}] (${t.confidence})`);
            } else {
              console.log(`    <-[${t.predicate}]- ${t.related_name} [${t.related_type}] (${t.confidence})`);
            }
          }
        }
        if (detail.properties.length > 0) {
          console.log("  Properties:");
          for (const p of detail.properties) {
            console.log(`    ${p.key}: ${p.value}`);
          }
        }
      }
    } finally {
      db.close();
    }
  });

program
  .command("merge <entity1> <entity2>")
  .description("Merge two entities (keep first, absorb second)")
  .action((entity1, entity2) => {
    const db = openDb(program.opts());
    try {
      db.merge(entity1, entity2);
      console.log(`Merged "${entity2}" into "${entity1}"`);
    } finally {
      db.close();
    }
  });

program
  .command("prune")
  .description("Remove orphaned entities")
  .option("--dry-run", "Show what would be pruned without deleting")
  .action((opts) => {
    const db = openDb(program.opts());
    try {
      const pruned = db.prune({ dryRun: opts.dryRun });
      if (pruned.length === 0) {
        console.log("No orphaned entities found.");
      } else {
        const verb = opts.dryRun ? "Would prune" : "Pruned";
        console.log(`${verb} ${pruned.length} entities: ${pruned.join(", ")}`);
      }
    } finally {
      db.close();
    }
  });

program
  .command("stats")
  .description("Show graph statistics")
  .action(() => {
    const db = openDb(program.opts());
    try {
      const s = db.stats();
      console.log(`Entities:   ${s.entity_count}`);
      console.log(`Triples:    ${s.triple_count}`);
      console.log(`Properties: ${s.property_count}`);
      if (s.top_predicates.length > 0) {
        console.log("Top predicates:");
        for (const p of s.top_predicates) {
          console.log(`  ${p.predicate}: ${p.count}`);
        }
      }
    } finally {
      db.close();
    }
  });

program
  .command("export")
  .description("Export entire graph")
  .option("--format <fmt>", "Output format: jsonl|dot", "jsonl")
  .action((opts) => {
    const db = openDb(program.opts());
    try {
      const data = db.exportAll();
      if (opts.format === "dot") {
        // Color palette for entity types
        const typeColors = {
          person: "#a8d5ff",
          place: "#b8e6b8",
          service: "#ffd5a8",
          organization: "#e6b8e6",
          concept: "#ffffb8",
          thing: "#e8e8e8",
          unknown: "#f0f0f0",
        };

        console.log("digraph knowledge_graph {");
        console.log('  rankdir=LR;');
        console.log('  node [shape=box, style=filled];');

        for (const e of data.entities) {
          const color = typeColors[e.entity_type] || typeColors.unknown;
          console.log(`  "${e.name}" [label="${e.display_name}\\n[${e.entity_type}]", fillcolor="${color}"];`);
        }

        for (const t of data.triples) {
          console.log(`  "${t.subject_name}" -> "${t.object_name}" [label="${t.predicate}"];`);
        }

        console.log("}");
      } else {
        for (const t of data.triples) {
          console.log(JSON.stringify({
            subject: t.subject_name,
            predicate: t.predicate,
            object: t.object_name,
            confidence: t.confidence,
            source: t.source,
          }));
        }
        for (const p of data.properties) {
          console.log(JSON.stringify({
            entity: p.entity_name,
            key: p.key,
            value: p.value,
            source: p.source,
          }));
        }
      }
    } finally {
      db.close();
    }
  });

program
  .command("import <file>")
  .description("Import data from JSONL file")
  .action((file) => {
    const db = openDb(program.opts());
    try {
      const content = readFileSync(resolve(file), "utf-8");
      const lines = content.split("\n").filter(Boolean);

      const triples = [];
      const properties = [];

      for (const line of lines) {
        const obj = JSON.parse(line);
        if (obj.predicate) {
          triples.push(obj);
        } else if (obj.key) {
          properties.push(obj);
        }
      }

      db.importData({ triples, properties });
      console.log(`Imported ${triples.length} triples, ${properties.length} properties`);
    } finally {
      db.close();
    }
  });

program
  .command("fuse <query>")
  .description("Query multiple sources and fuse results with RRF")
  .option("--sources <file>", "Path to sources config JSON", resolve(homedir(), ".openclaw", "kg-fusion-sources.json"))
  .option("--k <n>", "RRF constant (higher = smoother ranking)", "60")
  .option("--format <fmt>", "Output format: human|jsonl", "human")
  .action((query, opts) => {
    const db = openDb(program.opts());
    try {
      let sources = [];
      if (existsSync(opts.sources)) {
        const sourcesConfig = JSON.parse(readFileSync(opts.sources, "utf-8"));
        sources = sourcesConfig.sources || sourcesConfig;
      }

      const results = fuse(query, {
        graph: db,
        sources: sources.map(s => ({ ...s, type: "command" })),
        k: parseInt(opts.k),
      });

      if (opts.format === "jsonl") {
        for (const r of results) {
          console.log(JSON.stringify(r));
        }
      } else {
        if (results.length === 0) {
          console.log(`No results found for "${query}"`);
          return;
        }
        console.log(`Fusion results for "${query}" (k=${opts.k}):\n`);
        for (const r of results) {
          console.log(`[${r.source}] score: ${r.score.toFixed(4)}`);
          console.log(`  ${r.text.split('\n').join('\n  ')}`);
          console.log();
        }
      }
    } finally {
      db.close();
    }
  });

program
  .command("ingest")
  .description("Ingest data from sessions, markdown, and factmem")
  .option("--sessions <dir>", "Sessions directory", "/home/clawd/.openclaw/agents")
  .option("--markdown <paths...>", "Markdown paths to ingest")
  .option("--factmem <path>", "Factmem database path")
  .option("--all", "Ingest from all sources (sessions + markdown + factmem)")
  .option("--dry-run", "Preview without writing to database")
  .option("--verbose", "Show detailed progress")
  .option("--llm", "Use LLM for entity extraction")
  .option("--ollama-url <url>", "Ollama base URL for LLM extraction")
  .option("--model <name>", "LLM model name")
  .option("--fresh", "Ignore state file and reprocess everything")
  .option("--reset-state", "Delete state file and exit")
  .action(async (opts) => {
    const config = loadConfig();
    const statePath = config.ingestStatePath || resolve(homedir(), ".openclaw", "kg-ingest-state.json");

    // Handle --reset-state
    if (opts.resetState) {
      resetState(statePath);
      return;
    }

    const db = openDb(program.opts());
    
    try {
      const ingestOpts = {
        dryRun: opts.dryRun,
        verbose: opts.verbose,
        useLLM: opts.llm,
        ollamaUrl: opts.ollamaUrl || config.llm?.baseUrl,
        model: opts.model || config.llm?.model,
        fresh: opts.fresh,
        statePath: statePath,
      };

      let stats;

      if (opts.all) {
        // Ingest everything
        const sessionsDir = opts.sessions;
        const markdownPaths = opts.markdown || [
          resolve(homedir(), "shared"),
          resolve(homedir(), ".openclaw"),
        ];
        const factmemPath = opts.factmem || resolve(homedir(), "shared", "facts.db");

        stats = await ingestAll(db, sessionsDir, markdownPaths, factmemPath, ingestOpts);
      } else if (opts.markdown) {
        // Just markdown
        console.log("\n=== Ingesting Markdown Files ===");
        stats = ingestMarkdown(db, opts.markdown, ingestOpts);
      } else if (opts.factmem) {
        // Just factmem
        console.log("\n=== Ingesting Factmem Database ===");
        stats = ingestFactmem(db, opts.factmem, ingestOpts);
      } else {
        // Default: just sessions
        console.log("\n=== Ingesting Session Files ===");
        stats = await ingestSessions(db, opts.sessions, ingestOpts);
      }

      // Print summary
      console.log("\n=== Ingest Summary ===");
      if (stats.sessionsProcessed > 0) {
        console.log(`Sessions:   ${stats.sessionsProcessed} processed, ${stats.messagesProcessed} messages`);
      }
      if (stats.filesProcessed > 0) {
        console.log(`Markdown:   ${stats.filesProcessed} files`);
      }
      if (stats.factsProcessed > 0) {
        console.log(`Facts:      ${stats.factsProcessed}`);
      }
      if (stats.filesSkipped !== undefined && stats.filesSkipped > 0) {
        console.log(`Skipped:    ${stats.filesSkipped} unchanged files`);
      }
      console.log(`Entities:   ${stats.entitiesAdded}`);
      console.log(`Triples:    ${stats.triplesAdded}`);
      console.log(`Properties: ${stats.propertiesAdded}`);
      
      if (stats.errors.length > 0) {
        console.log(`\nErrors:     ${stats.errors.length}`);
        if (opts.verbose) {
          for (const err of stats.errors.slice(0, 10)) {
            console.log(`  - ${err}`);
          }
          if (stats.errors.length > 10) {
            console.log(`  ... and ${stats.errors.length - 10} more`);
          }
        }
      }
    } catch (err) {
      console.error(`Ingest failed: ${err}`);
      process.exitCode = 1;
    } finally {
      db.close();
    }
  });

program.parse();
