#!/usr/bin/env node

import { resolve, dirname } from "node:path";
import { existsSync, mkdirSync } from "node:fs";
import { homedir } from "node:os";
import { program } from "commander";
import { GraphDB } from "../../dist/lib/graph-db.js";
import { loadConfig } from "../../dist/lib/config.js";

function getDbPath(opts) {
  if (opts?.db) return resolve(opts.db);
  if (process.env.KG_DB_PATH) return resolve(process.env.KG_DB_PATH);
  
  // Load from config file
  const config = loadConfig();
  const dbPath = resolve(config.dbPath);
  
  // Ensure parent directory exists
  const dbDir = dirname(dbPath);
  if (!existsSync(dbDir)) mkdirSync(dbDir, { recursive: true });
  
  return dbPath;
}

function openDb(opts) {
  return new GraphDB(getDbPath(opts));
}

function getLLMConfig() {
  const config = loadConfig();
  return {
    enabled: !!(config.llm?.baseUrl || config.llm?.apiKey),
    url: config.llm?.baseUrl || "http://localhost:11434",
    model: config.llm?.model || "qwen2.5:14b",
    apiKey: config.llm?.apiKey
  };
}

// Simple Levenshtein distance for fuzzy matching
function levenshtein(a, b) {
  const matrix = [];

  for (let i = 0; i <= b.length; i++) {
    matrix[i] = [i];
  }

  for (let j = 0; j <= a.length; j++) {
    matrix[0][j] = j;
  }

  for (let i = 1; i <= b.length; i++) {
    for (let j = 1; j <= a.length; j++) {
      if (b.charAt(i - 1) === a.charAt(j - 1)) {
        matrix[i][j] = matrix[i - 1][j - 1];
      } else {
        matrix[i][j] = Math.min(
          matrix[i - 1][j - 1] + 1,
          matrix[i][j - 1] + 1,
          matrix[i - 1][j] + 1
        );
      }
    }
  }

  return matrix[b.length][a.length];
}

function findPotentialDuplicates(db, threshold = 0.8) {
  const entities = db.exportAll().entities;
  const duplicates = [];

  for (let i = 0; i < entities.length; i++) {
    for (let j = i + 1; j < entities.length; j++) {
      const e1 = entities[i];
      const e2 = entities[j];

      // Only compare entities of the same type
      if (e1.entity_type !== e2.entity_type) continue;

      const name1 = e1.name.toLowerCase();
      const name2 = e2.name.toLowerCase();

      // Skip if names are identical (already handled by merge)
      if (name1 === name2) continue;

      const distance = levenshtein(name1, name2);
      const maxLen = Math.max(name1.length, name2.length);
      const similarity = 1 - distance / maxLen;

      if (similarity >= threshold) {
        duplicates.push({
          entity1: e1.display_name,
          entity2: e2.display_name,
          type: e1.entity_type,
          similarity: similarity.toFixed(3),
        });
      }
    }
  }

  return duplicates;
}

program
  .name("kg-maintenance")
  .description("Knowledge graph maintenance tasks for cron jobs")
  .version("0.1.0")
  .option("--db <path>", "Database file path");

program
  .command("prune")
  .description("Remove orphaned entities (entities with no triples or properties)")
  .option("--dry-run", "Show what would be pruned without deleting")
  .option("--quiet", "Only output summary")
  .action((opts) => {
    const db = openDb(program.opts());
    try {
      const pruned = db.prune({ dryRun: opts.dryRun });

      if (!opts.quiet) {
        console.log(`=== Orphan Pruning Report ===`);
        console.log(`Date: ${new Date().toISOString()}`);
        console.log(`Database: ${getDbPath(program.opts())}`);
        console.log();
      }

      if (pruned.length === 0) {
        if (!opts.quiet) {
          console.log("✓ No orphaned entities found.");
        }
      } else {
        const verb = opts.dryRun ? "Would prune" : "Pruned";
        console.log(`${verb} ${pruned.length} orphaned entities:`);
        if (!opts.quiet) {
          for (const name of pruned) {
            console.log(`  - ${name}`);
          }
        }
      }
    } finally {
      db.close();
    }
  });

program
  .command("find-duplicates")
  .description("Find potential duplicate entities via fuzzy name matching")
  .option("--threshold <n>", "Similarity threshold (0-1)", "0.8")
  .option("--quiet", "Only output summary")
  .action((opts) => {
    const db = openDb(program.opts());
    try {
      const duplicates = findPotentialDuplicates(db, parseFloat(opts.threshold));

      if (!opts.quiet) {
        console.log(`=== Duplicate Detection Report ===`);
        console.log(`Date: ${new Date().toISOString()}`);
        console.log(`Database: ${getDbPath(program.opts())}`);
        console.log(`Threshold: ${opts.threshold}`);
        console.log();
      }

      if (duplicates.length === 0) {
        if (!opts.quiet) {
          console.log("✓ No potential duplicates found.");
        }
      } else {
        console.log(`Found ${duplicates.length} potential duplicate pairs:`);
        console.log();
        for (const dup of duplicates) {
          console.log(`  "${dup.entity1}" ↔ "${dup.entity2}"`);
          console.log(`  Type: ${dup.type}, Similarity: ${dup.similarity}`);
          console.log(`  → To merge: kg merge "${dup.entity1}" "${dup.entity2}"`);
          console.log();
        }
        console.log("⚠️  IMPORTANT: Review each pair manually before merging.");
        console.log("   Automated merging is NOT recommended due to risk of incorrect merges.");
      }
    } finally {
      db.close();
    }
  });

program
  .command("report")
  .description("Generate full maintenance report (prune + duplicates)")
  .option("--threshold <n>", "Similarity threshold for duplicates (0-1)", "0.8")
  .action((opts) => {
    const db = openDb(program.opts());
    try {
      console.log("╔═══════════════════════════════════════════════════════════════╗");
      console.log("║       Knowledge Graph Maintenance Report                     ║");
      console.log("╚═══════════════════════════════════════════════════════════════╝");
      console.log();
      console.log(`Date: ${new Date().toISOString()}`);
      console.log(`Database: ${getDbPath(program.opts())}`);
      console.log();

      // Stats
      const stats = db.stats();
      console.log("--- Graph Statistics ---");
      console.log(`Entities:   ${stats.entity_count}`);
      console.log(`Triples:    ${stats.triple_count}`);
      console.log(`Properties: ${stats.property_count}`);
      console.log();

      // Orphans
      console.log("--- Orphaned Entities (dry-run) ---");
      const orphans = db.prune({ dryRun: true });
      if (orphans.length === 0) {
        console.log("✓ No orphaned entities found.");
      } else {
        console.log(`⚠️  Found ${orphans.length} orphaned entities:`);
        for (const name of orphans.slice(0, 10)) {
          console.log(`  - ${name}`);
        }
        if (orphans.length > 10) {
          console.log(`  ... and ${orphans.length - 10} more`);
        }
        console.log();
        console.log("  To remove: kg-maintenance prune");
      }
      console.log();

      // Duplicates
      console.log("--- Potential Duplicates ---");
      const duplicates = findPotentialDuplicates(db, parseFloat(opts.threshold));
      if (duplicates.length === 0) {
        console.log("✓ No potential duplicates found.");
      } else {
        console.log(`⚠️  Found ${duplicates.length} potential duplicate pairs:`);
        for (const dup of duplicates.slice(0, 10)) {
          console.log(`  "${dup.entity1}" ↔ "${dup.entity2}" (similarity: ${dup.similarity})`);
        }
        if (duplicates.length > 10) {
          console.log(`  ... and ${duplicates.length - 10} more`);
        }
        console.log();
        console.log("  To merge: kg merge <entity1> <entity2>");
        console.log("  ⚠️  Review manually before merging!");
      }
      console.log();
      console.log("═══════════════════════════════════════════════════════════════");
    } finally {
      db.close();
    }
  });

program
  .command("ingest")
  .alias("seed")
  .description("Seed the knowledge graph from existing data sources")
  .option("--source <type>", "Data source: sessions, markdown, factmem, or all (default: all)", "all")
  .option(
    "--sessions-dir <path>",
    "Base directory for session files (default: ~/.openclaw/agents)",
    resolve(homedir(), ".openclaw", "agents")
  )
  .option(
    "--paths <paths...>",
    "Markdown paths to scan (default: shared and agent memory dirs)",
    [
      resolve(homedir(), "shared"),
      resolve(homedir(), "clawd", "memory"),
      resolve(homedir(), "gilfoyle", "memory"),
      resolve(homedir(), "monty", "memory"),
      resolve(homedir(), "sterling", "memory"),
    ]
  )
  .option(
    "--facts-db <path>",
    "Path to facts.db (default: ~/shared/facts.db)",
    resolve(homedir(), "shared", "facts.db")
  )
  .option("--llm [url]", "Use LLM extraction instead of NLP (URL optional if configured in ~/.openclaw/kg.json)")
  .option("--llm-model <model>", "LLM model to use (overrides config)")
  .option("--llm-api-key <key>", "API key for cloud LLM providers (overrides config)")
  .option("--concurrency <n>", "Number of concurrent LLM API calls (default 4)", "4")
  .option("--dry-run", "Show what would be ingested without adding to graph")
  .option("--verbose", "Show detailed progress")
  .action(async (opts) => {
    const { ingestSessions, ingestMarkdown, ingestFactmem, ingestAll } = await import("../../dist/lib/ingest.js");
    const db = openDb(program.opts());
    const config = loadConfig();
    const llmConfig = getLLMConfig();

    try {
      console.log("╔═══════════════════════════════════════════════════════════════╗");
      console.log("║       Knowledge Graph Ingestion                              ║");
      console.log("╚═══════════════════════════════════════════════════════════════╝");
      console.log();
      console.log(`Date: ${new Date().toISOString()}`);
      console.log(`Database: ${getDbPath(program.opts())}`);
      console.log(`Source: ${opts.source}`);
      if (opts.dryRun) {
        console.log("Mode: DRY RUN (no changes will be made)");
      }
      console.log();

      // Determine LLM configuration
      let useLLM = false;
      let ollamaUrl;
      let model;

      if (opts.llm !== undefined) {
        // --llm flag was passed (opt-in)
        useLLM = true;
        if (typeof opts.llm === "string") {
          // URL provided as argument
          ollamaUrl = opts.llm;
        } else {
          // No URL provided, try config then default
          ollamaUrl = llmConfig.url || "http://mac-mini.tailcd0984.ts.net:11434";
        }
      }
      // If --llm not passed, useLLM stays false (NLP is default)

      if (useLLM) {
        // Determine model: CLI flag > config > error
        if (opts.llmModel) {
          model = opts.llmModel;
        } else if (llmConfig?.model) {
          model = llmConfig.model;
        } else {
          model = "qwen2.5:14b"; // Final fallback
        }
      }

      let stats;
      const ingestOpts = {
        dryRun: opts.dryRun,
        verbose: opts.verbose,
        useLLM,
        ollamaUrl,
        model,
        apiKey: opts.llmApiKey || config.llm?.apiKey,
        chunkSize: config.llm?.chunkSize,
        concurrency: parseInt(opts.concurrency, 10) || 4,
      };

      if (ingestOpts.useLLM && opts.verbose) {
        console.log(`LLM extraction enabled: ${ingestOpts.ollamaUrl} (model: ${ingestOpts.model})`);
        if (ingestOpts.apiKey) {
          console.log(`Using API key: ${ingestOpts.apiKey.substring(0, 8)}...`);
        }
      }

      switch (opts.source.toLowerCase()) {
        case "sessions":
        case "session":
          stats = await ingestSessions(db, opts.sessionsDir, ingestOpts);
          break;
        case "markdown":
        case "md":
          stats = await ingestMarkdown(db, opts.paths, ingestOpts);
          break;
        case "factmem":
        case "facts":
          stats = ingestFactmem(db, opts.factsDb, ingestOpts);
          break;
        case "all":
        default:
          stats = await ingestAll(db, opts.sessionsDir, opts.paths, opts.factsDb, ingestOpts);
          break;
      }

      console.log();
      console.log("=== Ingestion Summary ===");
      if (opts.source === "sessions" || opts.source === "all") {
        console.log(`Session files processed: ${stats.sessionsProcessed}`);
        console.log(`Messages processed: ${stats.messagesProcessed}`);
      }
      if (opts.source === "markdown" || opts.source === "all") {
        console.log(`Markdown files processed: ${stats.filesProcessed}`);
      }
      if (opts.source === "factmem" || opts.source === "all") {
        console.log(`Facts processed: ${stats.factsProcessed}`);
      }
      console.log(`Entities added: ${stats.entitiesAdded}`);
      console.log(`Triples added: ${stats.triplesAdded}`);
      console.log(`Properties added: ${stats.propertiesAdded}`);

      if (stats.errors.length > 0) {
        console.log();
        console.log(`⚠️  Encountered ${stats.errors.length} errors:`);
        for (const error of stats.errors.slice(0, 10)) {
          console.log(`  - ${error}`);
        }
        if (stats.errors.length > 10) {
          console.log(`  ... and ${stats.errors.length - 10} more`);
        }
      } else {
        console.log();
        console.log("✓ Ingestion completed successfully!");
      }

      if (opts.dryRun) {
        console.log();
        console.log("ℹ️  This was a dry run. Run without --dry-run to apply changes.");
      }
    } finally {
      db.close();
    }
  });

program
  .command("test-file <file>")
  .description("Process a single file and show exactly what would be extracted (no DB writes)")
  .option("--limit <n>", "Max entities to show", "50")
  .option("--llm [url]", "Use LLM extraction instead of NLP (URL optional if configured in ~/.openclaw/kg.json)")
  .option("--llm-model <model>", "LLM model to use (overrides config)")
  .option("--llm-api-key <key>", "API key for cloud LLM providers (overrides config)")
  .action(async (file, opts) => {
    const { readFileSync, createReadStream } = await import("node:fs");
    const { createInterface } = await import("node:readline");
    const config = loadConfig();
    const llmConfig = getLLMConfig();
    const limit = parseInt(opts.limit, 10);
    
    // Determine LLM configuration (same logic as ingest)
    let useLLM = false;
    let ollamaUrl;
    let model;

    if (opts.llm !== undefined) {
      // --llm flag was passed (opt-in)
      useLLM = true;
      if (typeof opts.llm === "string") {
        // URL provided as argument
        ollamaUrl = opts.llm;
      } else {
        // No URL provided, try config then default
        ollamaUrl = llmConfig.url || "http://mac-mini.tailcd0984.ts.net:11434";
      }
    }
    // If --llm not passed, useLLM stays false (NLP is default)

    if (useLLM) {
      // Determine model: CLI flag > config > fallback
      if (opts.llmModel) {
        model = opts.llmModel;
      } else if (llmConfig?.model) {
        model = llmConfig.model;
      } else {
        model = "qwen2.5:14b";
      }
    }

    const isSession = file.includes(".jsonl");

    if (isSession && useLLM) {
      // LLM-based extraction for sessions
      const { extractTriplesWithLLM, chunkMessages } = await import("../../dist/lib/llm-extract.js");
      
      console.log(`\n🤖 Using LLM extraction (${model})`);
      console.log(`File: ${file}\n`);

      // Read messages
      const messages = [];
      const rl = createInterface({ input: createReadStream(file, "utf-8"), crlfDelay: Infinity });

      for await (const line of rl) {
        try {
          const obj = JSON.parse(line);
          if (obj.type !== "message" || !obj.message) continue;
          const role = obj.message.role;
          if (role !== "user" && role !== "assistant") continue;

          let text = obj.message.content;
          if (Array.isArray(text)) {
            text = text.filter(b => b.type === "text").map(b => b.text).join("\n");
          }
          if (!text || text.length < 10) continue;

          messages.push({ role, text });
        } catch { /* skip bad lines */ }
      }

      console.log(`Messages: ${messages.length}`);

      // Chunk and process
      const chunks = chunkMessages(messages, config.llm?.chunkSize);
      console.log(`Chunks: ${chunks.length}\n`);

      const allTriples = [];
      const entityMap = new Map(); // name -> type

      for (let i = 0; i < chunks.length; i++) {
        console.log(`Processing chunk ${i + 1}/${chunks.length}...`);
        const triples = await extractTriplesWithLLM(chunks[i], {
          ollamaUrl: ollamaUrl,
          model: model,
          apiKey: opts.llmApiKey || config.llm?.apiKey,
          verbose: true,
        });
        
        console.log(`  ✓ Extracted ${triples.length} triples`);
        
        for (const t of triples) {
          allTriples.push(t);
          entityMap.set(t.subject.toLowerCase(), { name: t.subject, type: t.subject_type || "unknown" });
          entityMap.set(t.object.toLowerCase(), { name: t.object, type: t.object_type || "unknown" });
        }
      }

      console.log(`\n=== Results ===`);
      console.log(`Unique entities: ${entityMap.size}`);
      console.log(`Triples: ${allTriples.length}`);

      console.log(`\n=== Entities ===`);
      const entities = [...entityMap.values()];
      for (const e of entities.slice(0, limit)) {
        console.log(`  - ${e.name} (${e.type})`);
      }

      console.log(`\n=== Sample Triples ===`);
      for (const t of allTriples.slice(0, limit)) {
        console.log(`  ${t.subject} --[${t.predicate}]--> ${t.object}`);
      }

    } else if (isSession) {
      // NLP-based extraction for sessions
      const { extractEntities } = await import("../../dist/lib/entity-extract.js");
      
      const rl = createInterface({ input: createReadStream(file, "utf-8"), crlfDelay: Infinity });
      let msgCount = 0;
      const allEntities = new Map(); // name -> {type, count, sampleContext}

      for await (const line of rl) {
        try {
          const obj = JSON.parse(line);
          if (obj.type !== "message" || !obj.message) continue;
          const role = obj.message.role;
          if (role !== "user" && role !== "assistant") continue;

          let text = obj.message.content;
          if (Array.isArray(text)) {
            text = text.filter(b => b.type === "text").map(b => b.text).join("\n");
          }
          if (!text || text.length < 10) continue;

          msgCount++;
          const entities = extractEntities(text);
          for (const e of entities) {
            const key = e.name.toLowerCase();
            const existing = allEntities.get(key);
            if (existing) {
              existing.count++;
            } else {
              allEntities.set(key, {
                name: e.name,
                type: e.type,
                count: 1,
                context: text.substring(0, 120).replace(/\n/g, " ")
              });
            }
          }
        } catch { /* skip bad lines */ }
      }

      // Sort by count descending
      const sorted = [...allEntities.values()].sort((a, b) => b.count - a.count);

      console.log(`\nFile: ${file}`);
      console.log(`Messages processed: ${msgCount}`);
      console.log(`Unique entities found: ${allEntities.size}`);
      console.log(`\nTop ${Math.min(limit, sorted.length)} entities:\n`);
      console.log("  Count  Type          Name");
      console.log("  -----  ----          ----");
      for (const e of sorted.slice(0, limit)) {
        const typeStr = e.type.padEnd(12);
        const countStr = String(e.count).padStart(5);
        console.log(`  ${countStr}  ${typeStr}  ${e.name}`);
      }

      // Show some garbage candidates
      const garbage = sorted.filter(e =>
        e.name.length > 80 || e.name.includes("{") || e.name.includes("<") ||
        e.name.includes("//") || e.name.includes(".jsonl") || e.name.includes("```")
      );
      if (garbage.length > 0) {
        console.log(`\n⚠️  Likely garbage entities (${garbage.length}):`);
        for (const e of garbage.slice(0, 10)) {
          console.log(`  - "${e.name.substring(0, 100)}..." (${e.type}, count: ${e.count})`);
        }
      }

    } else {
      // Process as markdown (always NLP-based)
      const { extractEntities } = await import("../../dist/lib/entity-extract.js");
      const content = readFileSync(file, "utf-8");
      const entities = extractEntities(content);

      // Deduplicate
      const entityMap = new Map();
      for (const e of entities) {
        const key = e.name.toLowerCase();
        const existing = entityMap.get(key);
        if (existing) {
          existing.count++;
        } else {
          entityMap.set(key, { ...e, count: 1 });
        }
      }

      const sorted = [...entityMap.values()].sort((a, b) => b.count - a.count);

      console.log(`\nFile: ${file}`);
      console.log(`Total extractions: ${entities.length}`);
      console.log(`Unique entities: ${entityMap.size}`);
      console.log(`\nTop ${Math.min(limit, sorted.length)} entities:\n`);
      console.log("  Count  Type          Name");
      console.log("  -----  ----          ----");
      for (const e of sorted.slice(0, limit)) {
        const typeStr = e.type.padEnd(12);
        const countStr = String(e.count).padStart(5);
        console.log(`  ${countStr}  ${typeStr}  ${e.name}`);
      }
    }
  });

program
  .command("consolidate")
  .description("Clean up garbage triples and optionally review with LLM or interactively")
  .option("--auto", "Auto-cleanup only (garbage values, duplicates) — default behavior")
  .option("--llm", "Use LLM for review after auto-cleanup")
  .option("--interactive", "Interactive review of triples")
  .option("--dry-run", "Show what would be changed without changing")
  .option("--verbose", "Show details")
  .option("--entity <name>", "Only consolidate triples involving this entity")
  .action(async (opts) => {
    const db = openDb(program.opts());

    const GARBAGE_OBJECTS = [
      "unknown", "none", "n/a", "null", "undefined", "not specified",
      "not mentioned", "email address", "phone number", "email_address",
      "unspecified", "various", "multiple", "tbd", "to be determined",
      "unclear", "unknown entity", "unknown person", "unknown organization",
    ];

    let autoRejectedTriples = 0;
    let autoRejectedEntities = 0;
    let llmRejected = 0;
    let llmFixed = 0;
    let interactiveRejected = 0;
    let kept = 0;

    try {
      // ── Phase 1: Auto-cleanup ────────────────────────────────────────────
      console.log("=== Phase 1: Auto-cleanup ===\n");

      const allTriples = db.allTriples({ includeRejected: false });
      const filtered = opts.entity
        ? allTriples.filter(t =>
            t.subject.toLowerCase().includes(opts.entity.toLowerCase()) ||
            t.object.toLowerCase().includes(opts.entity.toLowerCase())
          )
        : allTriples;

      for (const triple of filtered) {
        const objLower = triple.object.toLowerCase().trim();
        const subjLower = triple.subject.toLowerCase().trim();

        // Garbage object values
        if (GARBAGE_OBJECTS.includes(objLower)) {
          if (opts.verbose) {
            console.log(`  [GARBAGE-OBJ] #${triple.id}: ${triple.subject} -[${triple.predicate}]-> ${triple.object}`);
          }
          if (!opts.dryRun) db.rejectTriple(triple.id);
          autoRejectedTriples++;
          continue;
        }

        // Self-referential triples
        if (subjLower === objLower) {
          if (opts.verbose) {
            console.log(`  [SELF-REF]    #${triple.id}: ${triple.subject} -[${triple.predicate}]-> ${triple.object}`);
          }
          if (!opts.dryRun) db.rejectTriple(triple.id);
          autoRejectedTriples++;
          continue;
        }

        // Garbage subject values
        if (GARBAGE_OBJECTS.includes(subjLower)) {
          if (opts.verbose) {
            console.log(`  [GARBAGE-SUB] #${triple.id}: ${triple.subject} -[${triple.predicate}]-> ${triple.object}`);
          }
          if (!opts.dryRun) db.rejectTriple(triple.id);
          autoRejectedTriples++;
          continue;
        }

        // Very long garbage entities (likely extracted code/file paths)
        if (triple.object.length > 200 || triple.subject.length > 200) {
          if (opts.verbose) {
            console.log(`  [TOO-LONG]    #${triple.id}: ${triple.subject.substring(0, 60)}...`);
          }
          if (!opts.dryRun) db.rejectTriple(triple.id);
          autoRejectedTriples++;
          continue;
        }

        // Object looks like a file path or URL fragment
        if (
          triple.object.includes("://") ||
          triple.object.includes("\\") ||
          triple.object.match(/^\/.+\.(ts|js|json|py|sh|md)$/)
        ) {
          if (opts.verbose) {
            console.log(`  [FILE-PATH]   #${triple.id}: ${triple.subject} -[${triple.predicate}]-> ${triple.object}`);
          }
          if (!opts.dryRun) db.rejectTriple(triple.id);
          autoRejectedTriples++;
          continue;
        }
      }

      // Auto-detect duplicate entities (name containment)
      if (!opts.entity) {
        const allEntities = db.exportAll().entities.filter(e => !e.rejected);
        const processed = new Set();

        for (let i = 0; i < allEntities.length; i++) {
          const e1 = allEntities[i];
          const n1 = e1.name;
          if (processed.has(n1)) continue;

          for (let j = i + 1; j < allEntities.length; j++) {
            const e2 = allEntities[j];
            const n2 = e2.name;
            if (processed.has(n2)) continue;

            // Check if names are variants of the same entity (e.g., "adam" vs "adam kropp")
            // Must share the same word tokens — not just substring match
            if (n1 !== n2) {
              const words1 = new Set(n1.split(/[\s'-]+/).filter(w => w.length > 1));
              const words2 = new Set(n2.split(/[\s'-]+/).filter(w => w.length > 1));
              const shorter = n1.length <= n2.length ? n1 : n2;
              const longer = n1.length <= n2.length ? n2 : n1;
              const shorterWords = n1.length <= n2.length ? words1 : words2;
              const longerWords = n1.length <= n2.length ? words2 : words1;

              // Every word in the shorter name must appear in the longer name
              // e.g., "adam" → ["adam"], "adam kropp" → ["adam", "kropp"] — "adam" ⊂ "adam kropp" ✓
              // e.g., "calendar" → ["calendar"], "noah's calendar" → ["noah", "calendar"] — "calendar" ⊄ not a name variant
              const allShorterWordsInLonger = [...shorterWords].every(w => longerWords.has(w));
              // The longer name should only add 1-2 words (not a totally different entity)
              const addedWords = longerWords.size - shorterWords.size;

              if (allShorterWordsInLonger && addedWords <= 2 && addedWords >= 1 && shorterWords.size >= 1) {
                if (opts.verbose) {
                  console.log(`  [DUPLICATE]   Merging "${shorter}" into "${longer}"`);
                }
                if (!opts.dryRun) {
                  try {
                    db.merge(longer, shorter);
                    autoRejectedEntities++;
                    processed.add(shorter);
                  } catch {
                    // Merge failed — skip
                  }
                } else {
                  autoRejectedEntities++;
                }
              }
            }
          }
        }
      }

      console.log(`Auto-rejected: ${autoRejectedTriples} triples (garbage values)`);
      if (autoRejectedEntities > 0) {
        console.log(`Auto-merged:   ${autoRejectedEntities} entities (duplicates)`);
      }

      // ── Phase 2: LLM Review ──────────────────────────────────────────────
      if (opts.llm) {
        console.log("\n=== Phase 2: LLM Review ===\n");
        const config = loadConfig();
        const llmUrl = config.llm?.baseUrl || "http://mac-mini.tailcd0984.ts.net:11434";
        const llmModel = config.llm?.model || "qwen2.5:14b";
        const apiKey = config.llm?.apiKey;

        const remaining = db.allTriples({ includeRejected: false });
        const toReview = opts.entity
          ? remaining.filter(t =>
              t.subject.toLowerCase().includes(opts.entity.toLowerCase()) ||
              t.object.toLowerCase().includes(opts.entity.toLowerCase())
            )
          : remaining;

        if (toReview.length === 0) {
          console.log("No triples to review.");
        } else {
          // Batch into chunks of 50
          const BATCH = 50;
          for (let i = 0; i < toReview.length; i += BATCH) {
            const batch = toReview.slice(i, i + BATCH);
            const prompt = `You are reviewing knowledge graph triples for accuracy and quality. For each triple below, respond with exactly one of:
- "keep" — if the triple is correct and useful
- "reject" — if it is incorrect, nonsensical, low-value, or garbage
- "fix: <new-subject> | <new-predicate> | <new-object>" — if it's roughly correct but has errors

Respond with a JSON array of objects: [{id: <id>, action: "keep"|"reject"|"fix", fix?: {subject, predicate, object}}]

Triples to review:
${JSON.stringify(batch.map(t => ({ id: t.id, subject: t.subject, predicate: t.predicate, object: t.object })), null, 2)}

Respond with ONLY the JSON array, no other text.`;

            try {
              let responseText;

              if (apiKey) {
                // Cloud LLM (OpenAI-compatible)
                const baseUrl = llmUrl.replace(/\/+$/, "");
                const resp = await fetch(`${baseUrl}/chat/completions`, {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    "Authorization": `Bearer ${apiKey}`,
                  },
                  body: JSON.stringify({
                    model: llmModel,
                    messages: [{ role: "user", content: prompt }],
                    temperature: 0,
                  }),
                });
                const data = await resp.json();
                responseText = data.choices?.[0]?.message?.content || "[]";
              } else {
                // Ollama
                const resp = await fetch(`${llmUrl}/api/chat`, {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({
                    model: llmModel,
                    messages: [{ role: "user", content: prompt }],
                    stream: false,
                    options: { temperature: 0 },
                  }),
                });
                const data = await resp.json();
                responseText = data.message?.content || "[]";
              }

              // Parse response
              const jsonMatch = responseText.match(/\[[\s\S]*\]/);
              if (!jsonMatch) continue;

              const decisions = JSON.parse(jsonMatch[0]);

              for (const d of decisions) {
                if (d.action === "reject") {
                  if (!opts.dryRun) db.rejectTriple(d.id);
                  llmRejected++;
                  if (opts.verbose) {
                    const t = batch.find(b => b.id === d.id);
                    if (t) console.log(`  [LLM-REJECT] #${t.id}: ${t.subject} -[${t.predicate}]-> ${t.object}`);
                  }
                } else if (d.action === "fix" && d.fix) {
                  if (!opts.dryRun) {
                    db.rejectTriple(d.id);
                    db.addTriple(d.fix.subject, d.fix.predicate, d.fix.object);
                  }
                  llmFixed++;
                  if (opts.verbose) {
                    const t = batch.find(b => b.id === d.id);
                    if (t) console.log(`  [LLM-FIX]    #${t.id}: ${t.subject} -[${t.predicate}]-> ${t.object} => ${d.fix.subject} -[${d.fix.predicate}]-> ${d.fix.object}`);
                  }
                }
              }
            } catch (err) {
              console.error(`  LLM error on batch starting at ${i}: ${err}`);
            }
          }
          console.log(`LLM-rejected: ${llmRejected} triples`);
          console.log(`LLM-fixed:    ${llmFixed} triples`);
        }
      }

      // ── Phase 3: Interactive Review ───────────────────────────────────────
      if (opts.interactive) {
        console.log("\n=== Phase 3: Interactive Review ===\n");
        console.log("For each triple, press: [K]eep / [R]eject / [F]ix / [S]kip\n");

        const { createInterface } = await import("node:readline/promises");
        const rl = createInterface({ input: process.stdin, output: process.stdout });

        const remaining = db.allTriples({ includeRejected: false });
        const toReview = opts.entity
          ? remaining.filter(t =>
              t.subject.toLowerCase().includes(opts.entity.toLowerCase()) ||
              t.object.toLowerCase().includes(opts.entity.toLowerCase())
            )
          : remaining;

        let idx = 0;
        for (const triple of toReview) {
          idx++;
          process.stdout.write(`[${idx}/${toReview.length}] ${triple.subject} -[${triple.predicate}]-> ${triple.object}`);
          if (triple.source) process.stdout.write(` (src: ${triple.source})`);
          process.stdout.write("\n");

          const answer = await rl.question("  [K]eep / [R]eject / [F]ix / [S]kip > ");
          const choice = answer.trim().toLowerCase();

          if (choice === "r") {
            if (!opts.dryRun) db.rejectTriple(triple.id);
            interactiveRejected++;
            console.log("  → Rejected\n");
          } else if (choice === "f") {
            const newSubject = await rl.question(`  New subject [${triple.subject}]: `);
            const newPredicate = await rl.question(`  New predicate [${triple.predicate}]: `);
            const newObject = await rl.question(`  New object [${triple.object}]: `);
            if (!opts.dryRun) {
              db.rejectTriple(triple.id);
              db.addTriple(
                newSubject.trim() || triple.subject,
                newPredicate.trim() || triple.predicate,
                newObject.trim() || triple.object
              );
            }
            llmFixed++;
            console.log("  → Fixed\n");
          } else if (choice === "k") {
            kept++;
            console.log("  → Kept\n");
          } else {
            // Skip (or enter)
            console.log("  → Skipped\n");
          }
        }

        rl.close();
      }

      // Count remaining kept triples
      if (!opts.interactive) {
        kept = db.allTriples({ includeRejected: false }).length;
      }

      // ── Summary ───────────────────────────────────────────────────────────
      console.log("\n=== Consolidation Results ===");
      console.log(`Auto-rejected:          ${autoRejectedTriples} triples (garbage values)`);
      if (autoRejectedEntities > 0) {
        console.log(`Auto-merged:            ${autoRejectedEntities} entities (duplicates)`);
      }
      if (opts.llm) {
        console.log(`LLM-rejected:           ${llmRejected} triples`);
        console.log(`LLM-fixed:              ${llmFixed} triples`);
      }
      if (opts.interactive) {
        console.log(`Interactively rejected: ${interactiveRejected} triples`);
      }
      console.log(`Kept:                   ${kept} triples`);

      if (opts.dryRun) {
        console.log("\n(Dry run — no changes made)");
      }
    } finally {
      db.close();
    }
  });

program.parse();
